# Core app
NEXT_PUBLIC_APP_NAME=JobRadar

# Live data providers (do not commit real keys)
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=
FRANCE_TRAVAIL_SCOPE=api_offresdemploiv2 o2dsoffre
FRANCE_TRAVAIL_TOKEN_URL=https://entreprise.francetravail.fr/connexion/oauth2/access_token?realm=/partenaire
FRANCE_TRAVAIL_SEARCH_URL=https://api.francetravail.io/partenaire/offresdemploi/v2/offres/search

# Database
# Required for live-db mode and refresh persistence.
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Optional map provider
NEXT_PUBLIC_MAPBOX_TOKEN=

# Optional alerting
RESEND_API_KEY=

# Ops security (Stage 4)
# Required to access /api/ops/refresh and trigger manual refresh from /ops.
ADMIN_OPS_TOKEN=

# Optional cache
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
